# Docker Compose runtime for backend container
DATABASE_URL=postgresql+asyncpg://app_user:CHANGEME_PASSWORD@127.0.0.1:5433/foxpos
DATABASE_SCHEMA=dunkin_mart

DATA_MODE=postgres
DATA_DIR=/app/data

# Redis remains optional in this round. The service can be enabled with the realtime profile.
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=CHANGEME
OPENAI_BASE_URL=http://localhost:8002/v1
OPENAI_MODEL=your-model-name
OPENAI_COMPLEX_MODEL=GLM-5.1-UD-IQ3_S-00001-of-00007.gguf

APP_ENV=docker
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8100,http://127.0.0.1:8100
PRODUCTION_CHECK_INTERVAL_MINUTES=5
PRODUCTION_ALERT_WINDOW_MINUTES=60
PRODUCTION_LEAD_TIME_MINUTES=60
BUSINESS_START_HOUR=8
BUSINESS_END_HOUR=22
AUDIT_LOG_PATH=logs/audit.jsonl
EVENTS_CONFIG_PATH=config/events.json
RAG_DOC_DIR=sample_docs
RAG_INDEX_DIR=.rag
RAG_MIN_SCORE=0.5

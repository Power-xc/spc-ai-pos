# Database (PostgreSQL)
# For the PostgreSQL-backed round, copy `.env.postgres.example` instead.
DATABASE_URL=postgresql+asyncpg://brpos:brpos@localhost:5432/br_pos
DATABASE_SCHEMA=dunkin_mart

# Data mode
DATA_MODE=file
DATA_DIR=/data/sapie/tax/BR-POS-App-UX-PoC/data

# Redis (optional in this round)
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-xxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPLEX_MODEL=gpt-4o

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
PRODUCTION_CHECK_INTERVAL_MINUTES=5
PRODUCTION_ALERT_WINDOW_MINUTES=60
PRODUCTION_LEAD_TIME_MINUTES=60
BUSINESS_START_HOUR=8
BUSINESS_END_HOUR=22
AUDIT_LOG_PATH=logs/audit.jsonl
EVENTS_CONFIG_PATH=config/events.json
RAG_DOC_DIR=sample_docs
RAG_INDEX_DIR=.rag
RAG_MIN_SCORE=0.5

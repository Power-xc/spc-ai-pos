# ─────────────────────────────────────────────────────────────
# FoxPOS backend — environment template.
# Copy to `.env` and adjust for your setup. Never commit a real `.env`.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL). Matches the `postgres` service in docker-compose.yml
# (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB, exposed on host port 5433).
DATABASE_URL=postgresql+asyncpg://app_user:CHANGEME_PASSWORD@localhost:5433/foxpos
DATABASE_SCHEMA=dunkin_mart

# Data source: `postgres` (read from the DB) or `file` (local dataset in DATA_DIR).
DATA_MODE=postgres
# Optional — defaults to <repo>/data when unset.
# DATA_DIR=./data

# Redis (optional — only used by the `realtime` SSE fan-out profile).
REDIS_URL=redis://localhost:6379/0

# LLM gateway (OpenAI-compatible endpoint; point at your self-hosted server).
OPENAI_API_KEY=EMPTY
OPENAI_BASE_URL=http://localhost:8002/v1
OPENAI_MODEL=your-model-name
OPENAI_COMPLEX_MODEL=your-model-name

# App
APP_ENV=development
LOG_LEVEL=INFO
# Frontend origins allowed by CORS (PIP POS desktop / mobile dev servers).
CORS_ORIGINS=http://localhost:5181,http://localhost:5186,http://localhost:8100
PRODUCTION_CHECK_INTERVAL_MINUTES=5
PRODUCTION_ALERT_WINDOW_MINUTES=60
PRODUCTION_LEAD_TIME_MINUTES=60
BUSINESS_START_HOUR=8
BUSINESS_END_HOUR=22
AUDIT_LOG_PATH=logs/audit.jsonl
EVENTS_CONFIG_PATH=config/events.json
RAG_DOC_DIR=sample_docs
RAG_INDEX_DIR=.rag
RAG_MIN_SCORE=0.5

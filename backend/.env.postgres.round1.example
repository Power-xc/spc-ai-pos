# PostgreSQL-first backend mode
DATA_MODE=database
DATABASE_URL=postgresql+asyncpg://brpos:brpos@localhost:5432/br_pos
DATABASE_SCHEMA=dunkin_mart

# File dataset remains useful for fallback/seed preparation
DATA_DIR=/data/sapie/tax/BR-POS-App-UX-PoC/data

# Redis is optional in this round
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPLEX_MODEL=gpt-4o

# Business hours / jobs
PRODUCTION_CHECK_INTERVAL_MINUTES=5
PRODUCTION_ALERT_WINDOW_MINUTES=60
PRODUCTION_LEAD_TIME_MINUTES=60
BUSINESS_START_HOUR=8
BUSINESS_END_HOUR=22

# Files
AUDIT_LOG_PATH=logs/audit.jsonl
EVENTS_CONFIG_PATH=config/events.json

# PostgreSQL ledger for dashboard / alerts / orders / chat
DATABASE_URL=postgresql+asyncpg://brpos:brpos@localhost:5432/br_pos
DATABASE_SCHEMA=dunkin_mart

# Run against PostgreSQL instead of local file dataset
DATA_MODE=postgres
DATA_DIR=/data/sapie/tax/BR-POS-App-UX-PoC/data

# Redis is optional in this round. Keep for future SSE fan-out only.
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=EMPTY
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_MODEL=qwen3.5-27b
OPENAI_COMPLEX_MODEL=qwen3.5-27b

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
PRODUCTION_CHECK_INTERVAL_MINUTES=5
PRODUCTION_ALERT_WINDOW_MINUTES=60
PRODUCTION_LEAD_TIME_MINUTES=60
BUSINESS_START_HOUR=8
BUSINESS_END_HOUR=22
AUDIT_LOG_PATH=logs/audit.jsonl
EVENTS_CONFIG_PATH=config/events.json
RAG_DOC_DIR=sample_docs
RAG_INDEX_DIR=.rag
RAG_MIN_SCORE=0.5
